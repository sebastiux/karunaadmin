# Copy to .env for local development.

# --- Database (Railway provides MYSQL_URL / DATABASE_URL automatically) ---
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/karunaadmin

# --- Auth ---
JWT_SECRET=please-change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ADMIN_EMAIL=admin@karuna.app
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# --- Grok / xAI (leave GROK_API_KEY empty to run AI in deterministic mock mode) ---
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.3

# --- Resend email notifications (leave RESEND_API_KEY empty to log-only) ---
RESEND_API_KEY=
# Must be a verified domain in Resend (onboarding@resend.dev only mails yourself)
RESEND_FROM=Karuna Admin <onboarding@resend.dev>
# Public app URL used for links inside emails, e.g. https://karunaadmin-production.up.railway.app
APP_BASE_URL=

# --- CORS: comma-separated origins, or * for all (dev only) ---
CORS_ORIGINS=*
