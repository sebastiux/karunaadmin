# Base URL of the FastAPI backend. In dev, leave empty to use the Vite proxy.
# In production (Railway), set to your backend service URL, e.g.
# VITE_API_URL=https://karuna-api.up.railway.app
VITE_API_URL=

# Optional: Node realtime gateway WebSocket URL for live Kanban updates.
# VITE_REALTIME_URL=wss://karuna-realtime.up.railway.app
VITE_REALTIME_URL=

# Dev-only: backend target for the Vite proxy (defaults to http://localhost:8000)
VITE_DEV_API=http://localhost:8000
